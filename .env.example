# ============================================
# LiteLLM / LLM Settings
# ============================================
LITELLM_API_KEY=your-litellm-api-key
LITELLM_BASE_URL=http://host.docker.internal:8023/
LITELLM_MODEL_NAME=ollama/llama3.1:latest
LITELLM_REQUEST_TIMEOUT=30
LITELLM_MAX_TOKENS=2048
LITELLM_TEMPERATURE=0.2
LITELLM_MAX_RETRIES=1
LITELLM_MASTER_KEY=sk-<your-litellm-master-key>
LITELLM_UI_USERNAME=your-litellm-ui-username
LITELLM_UI_PASSWORD=your-litellm-ui-password

# ============================================
# PostgreSQL Settings
# ============================================
POSTGRES_USER=chatuser
POSTGRES_PASSWORD=change-postgres-password
POSTGRES_DB=chatdb

# ============================================
# LangSmith Settings
# ============================================
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=agent-project
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ============================================
# Redis Cache Settings
# ============================================
REDIS_PASSWORD=change-redis-password
REDIS_URL=redis://:change-redis-password@localhost:6379/0
REDIS_CACHE_TTL_SECONDS=600
ENABLE_RESPONSE_CACHE=true
REDIS_MAX_CONNECTIONS=50
CACHE_SENSITIVE_PATTERNS=sk-,api_key,password,secret,token,authorization,bearer

# ============================================
# Frontend Settings
# ============================================
VITE_API_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# MCP Tool Settings
# ============================================
MCP_ENABLED_TOOLS=tavily_search
TAVILY_API_KEY=your-tavily-api-key
TAVILY_TOPIC=general
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=3
TAVILY_TIMEOUT_SECONDS=8
TAVILY_MAX_RETRIES=1
MCP_TOOL_TIMEOUT_MS=5000
MCP_TOOL_MAX_RETRIES=1
MCP_TOOL_INITIAL_BACKOFF_MS=100

# ============================================
# Orchestrator Settings
# ============================================
ORCHESTRATOR_HISTORY_TURNS=6
ORCHESTRATOR_TOOL_CONTEXT_MAX_CHARS=2500
CHAT_HISTORY_MAX_TURNS=10

# ============================================
# OpenTelemetry Settings
# ============================================
OTEL_SERVICE_NAME=chat-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
LOKI_PUSH_URL=http://loki:3100/loki/api/v1/push

# ============================================
# Grafana Settings
# ============================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
